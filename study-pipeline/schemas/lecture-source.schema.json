{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LectureSource",
  "type": "object",
  "required": ["courseId", "lectureId", "title", "sourcePdfPath"],
  "properties": {
    "courseId": { "type": "string" },
    "lectureId": { "type": "string" },
    "title": { "type": "string" },
    "instructor": { "type": "string" },
    "date": { "type": "string" },
    "sourcePdfPath": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
